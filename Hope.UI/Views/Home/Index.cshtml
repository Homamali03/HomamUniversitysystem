@{
    ViewData["Title"] = "Home Page";
}
<html>
    <head>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css">
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <style>
            .card-title{
                font-size: 25px;
                color: white;
            }
            .card-body{
                background-color: #4154f1;
            }
            .Counter{
             color: white;
             font-size: 25px;
            }
        </style>
    </head>
    <body>
        <div class="row">
            <div class="col-md-6">
                <div class="card info-card customers-card" >
                    <div class="card-body" >
                        <div class="card-title">
                        Number Of Users
                        </div>
                        <div class="d-flex align-items-center">
                            <div class="card-icon rounded-circle d-flex align-items-center">
                                <i class="bi bi-people-fill" style="font-size:50px; color:white"></i>
                            </div>
                            <div class="ps-3 Counter" >
                                50
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card info-card customers-card">
                    <div class="card-body">
                        <div class="card-title">
                            Number Of Students
                        </div>
                        <div class="d-flex align-items-center">
                            <div class="card-icon rounded-circle d-flex align-items-center">
                                <i class="bi bi-people-fill" style="font-size:50px;color:white"></i>
                            </div>
                            <div class="ps-3 Counter" >
                                50
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <script>
            $('.Counter').each(function () {
                $(this).prop('Counter', 0).animate({
                    Counter: $(this).text()
                }, 
                    {
                        duration: 5000,
                        easing: 'swing',
                        step: function (now) {
                            $(this).text(Math.ceil(now));
                        }
                    });
            });
        </script>
        
    </body>
</html>
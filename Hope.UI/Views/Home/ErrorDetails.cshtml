@{
}
@model List<Hope.Infrastructure.DTO.ErrorLogDTO>
<html>
<head>
    <script src=" https://code.jquery.com/jquery-3.7.1.js"></script>
    <script src="https://cdn.datatables.net/2.3.8/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.2.6/js/dataTables.buttons.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.2.6/js/buttons.dataTables.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.2.6/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.2.6/js/buttons.print.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.8/css/dataTables.dataTables.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.2.6/css/buttons.dataTables.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css">

</head>
<body>
    <div class="constainer">
        <div class="row">
            <div class="col-md-6">
                <h3>Get All Error Details</h3>
            </div>
            

        </div>
        <div class="row">
            <div class="col-md-12">
                <table id="example" class="display" width="130%">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Error Exception</th>
                            <th>Error Message</th>
                            <th>Stack Trace</th>
                            <th>Trasnaction Date</th>
                            <th>Module Name</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Hope.Infrastructure.DTO.ErrorLogDTO item in Model)
                        {
                            <tr>
                                <td>@item.FullName</td>
                                <td>@item.ErrorException</td>
                                <td>@item.ErrorMessage</td>
                                <td>@item.StackTrace</td>
                                <td>@item.Trasnaction</td>
                                <td>@item.ModuleName</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>


    
    <script>
                new DataTable('#example', {
            layout: {
                topStart: {
                    buttons: ['copy', 'csv', 'excel', 'pdf', 'print']
                }
            }
            columns: [{ width: '15%' }, { width: '15%' }, { width: '15%' }, { width: '65%' }, { width: '10%' },{ width: '10%' }]
        });
               
        
            // Initialize the DataTable
        $(document).ready(function () {
          $('#example').DataTable({

            // Enable automatic calculation
            // of column widths in the DataTable
            autoWidth: true
          });
        });
    </script>
</body>
</html>


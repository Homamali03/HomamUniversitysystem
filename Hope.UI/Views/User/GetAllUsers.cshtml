@{
}
@model List<Hope.Infrastructure.DTO.UserDTO>;
<html >
    <head>
        <script src="https://code.jquery.com/jquery-3.7.1.js"></script>
        <script src="https://cdn.datatables.net/2.3.8/js/dataTables.js"></script>
        <script src="https://cdn.datatables.net/buttons/3.2.6/js/dataTables.buttons.js"></script>
        <script src="https://cdn.datatables.net/buttons/3.2.6/js/buttons.dataTables.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
        <script src="https://cdn.datatables.net/buttons/3.2.6/js/buttons.html5.min.js"></script>
        <script src="https://cdn.datatables.net/buttons/3.2.6/js/buttons.print.min.js"></script>
        <link rel="stylesheet" href="https://cdn.datatables.net/2.3.8/css/dataTables.dataTables.css" />
        <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.2.6/css/buttons.dataTables.css" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css">

    </head>
    <body>
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h3>Get All Users</h3>
                </div>
                <div class="col-md-6" style="text-align:right">
                    <a href="Create">
                        <i class="fas fa-plus-circle"></i>
                        Add New User
                    </a>
                </div>

            </div>
            <div class="row">
                <div class="col-md-12">
                    <table id="example" class="table table-light">
                        <thead>
                            <tr>
                                <th>First Name</th>
                                <th>Last Name</th>
                                <th>Mobile</th>
                                <th>Gender</th>
                                <th>Date Of Birth</th>
                                <th>Address</th>
                                <th>Nationality</th>
                                <th>Email</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(Hope.Infrastructure.DTO.UserDTO item in Model)
                            {
                                <tr>
                                    <td>@item.FirstName</td>
                                    <td>@item.LastName</td>
                                    <td>@item.Mobile</td>
                                    <td>@item.GenderDisplayName</td>
                                    <td>@item.DateOfBirth</td>
                                    <td>@item.Address</td>
                                    <td>@item.NationalityName</td>
                                    <td>@item.Email</td>
                                    <td>
                                    <a asp-controller="User" asp-action="Update" asp-route-Id="@item.EncryptUserId"><i class="far fa-edit" style="color:dodgerblue"></i></a>
                                    <a asp-controller="User" asp-action="Delete" data-bs-toggle="modal" asp-route-Id="@item.UserId" data-bs-target="#exampleModal"><i class="far fa-trash-alt" style="color:red"></i></a>
                                    </td>
                                </tr>
                                
                            }
                    </tbody>
                    </table>
                </div>
            </div>
        </div>
       

        <!-- Modal -->
        <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title fs-5" id="exampleModalLabel">Delete</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        Are you sure want to delete this record?
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal" onclick="DeleteConfirmation()">Yes</button>
                    </div>
                </div>
            </div>
        </div>
        <script>
                new DataTable('#example', {
            layout: {
                topStart: {
                    buttons: ['copy', 'csv', 'excel', 'pdf', 'print']
                }
            }
        });
        function DeleteConfirmation(){
            $.ajax({
                type: 'POST',
                dataType: 'json',
                url: 'Delete',
                data: { id: '25' },
                success: function (Data) {
                    window.location.reload();
                    
                },
                error: function (XMLHttpRequest, textStatus, errorThrown) {

            }
        });
         }
        </script>
    </body>
</html>
